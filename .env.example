# Application
APP_NAME=AI Regulatory Knowledge Assistant
ENVIRONMENT=development

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend
STREAMLIT_SERVER_PORT=8501
API_BASE_URL=http://127.0.0.1:8000

# PostgreSQL and pgvector
POSTGRES_DB=regulatory_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Use this DATABASE_URL for local development from your host machine.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/regulatory_ai

# Docker Compose overrides DATABASE_URL for containers:
# postgresql://postgres:postgres@postgres:5432/regulatory_ai

# OpenAI
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
